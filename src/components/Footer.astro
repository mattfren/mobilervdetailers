---
import { getMessengerAction, getQuoteAction, isConfiguredUrl, site } from "../data/site";
import SocialLinks from "./SocialLinks.astro";

const messengerAction = getMessengerAction();
const quoteAction = getQuoteAction();
const hasPaymentUrl = isConfiguredUrl(site.paymentUrl);
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src={site.images.logo} alt="Mobile RV Detailers" width="190" height="58" />
      <p>Mobile RV exterior detailing based in Canton, TX.</p>
      <SocialLinks compact />
    </div>

    <div>
      <h2 class="footer-heading">Explore</h2>
      <ul class="footer-links">
        <li><a href="/">Home</a></li>
        <li><a href="/services/">Services</a></li>
        <li><a href="/gallery/">Gallery</a></li>
        <li><a href="/service-areas/">Service Areas</a></li>
        <li><a href="/about/">About</a></li>
      </ul>
    </div>

    <div>
      <h2 class="footer-heading">Contact</h2>
      <ul class="footer-links">
        <li><a href={quoteAction.href} target={quoteAction.external ? "_blank" : undefined} rel={quoteAction.external ? "noreferrer" : undefined}>Request Quote</a></li>
        <li><a href={messengerAction.href} target="_blank" rel="noreferrer">Facebook Messenger</a></li>
        <li><a href={site.phoneHref}>{site.phone}</a></li>
        {hasPaymentUrl && <li><a href={site.paymentUrl} target="_blank" rel="noreferrer">Pay Invoice</a></li>}
        <li><a href="/privacy/">Privacy</a></li>
        <li><a href="/terms/">Terms</a></li>
      </ul>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>&copy; {new Date().getFullYear()} Mobile RV Detailers. All rights reserved.</p>
    <p>Canton, TX | By appointment.</p>
  </div>
</footer>
