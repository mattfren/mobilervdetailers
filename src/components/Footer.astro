---
import { getBookingAction, getQuoteAction, getTextAction, site } from "../data/site";
import SocialLinks from "./SocialLinks.astro";

const bookingAction = getBookingAction();
const quoteAction = getQuoteAction();
const textAction = getTextAction();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <img src={site.images.logo} alt="Mobile RV Detailers" width="190" height="58" />
      <p>
        Premium mobile RV washing, wax soap hand drying, roof cleaning, black streak removal,
        and awning care based in Canton, TX.
      </p>
      <SocialLinks compact />
      <div class="footer-cta-row">
        <a class="btn btn-red" href={quoteAction.href} target={quoteAction.external ? "_blank" : undefined} rel={quoteAction.external ? "noreferrer" : undefined}>{quoteAction.label}</a>
        <a class="btn btn-ghost" href={textAction.href}>{textAction.label}</a>
      </div>
    </div>

    <div>
      <h2 class="footer-heading">Pages</h2>
      <ul class="footer-links">
        <li><a href="/">Home</a></li>
        {site.nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
        <li><a href="/book">Book</a></li>
      </ul>
    </div>

    <div>
      <h2 class="footer-heading">Services</h2>
      <ul class="footer-links">
        <li><a href="/services#exterior-rv-wash">Exterior RV Wash</a></li>
        <li><a href="/services#roof-cleaning">Roof Cleaning</a></li>
        <li><a href="/services#black-streak-removal">Black Streak Removal</a></li>
        <li><a href="/services#wax-soap-hand-dry">Wax Soap & Hand Dry</a></li>
      </ul>
    </div>

    <div>
      <h2 class="footer-heading">Contact</h2>
      <ul class="footer-links">
        <li><a href={site.phoneHref}>{site.phone}</a></li>
        <li><a href={site.facebookUrl} target="_blank" rel="noreferrer">Facebook</a></li>
        <li><a href="/service-areas">Canton, TX</a></li>
        <li><a href={bookingAction.href} target={bookingAction.external ? "_blank" : undefined} rel={bookingAction.external ? "noreferrer" : undefined}>{bookingAction.label}</a></li>
        <li><a href={site.paymentUrl} target="_blank" rel="noreferrer">Pay Invoice</a></li>
        <li><a href="/privacy">Privacy</a></li>
        <li><a href="/terms">Terms</a></li>
      </ul>
    </div>
  </div>
  <div class="container footer-bottom">
    <p>&copy; {new Date().getFullYear()} Mobile RV Detailers. All rights reserved.</p>
    <p>Canton, TX mobile RV detailing by appointment.</p>
  </div>
</footer>
