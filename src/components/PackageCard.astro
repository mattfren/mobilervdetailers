---
import type { Package } from "../data/packages";
import { launchApprovals } from "../data/site";

interface Props {
  item: Package;
  featured?: boolean;
}

const { item, featured = false } = Astro.props;
const statusLabel = launchApprovals.pricesApproved ? item.priceLabel : "Quote required";
---

<article class:list={["package-card", featured && "is-featured"]}>
  <p class="card-eyebrow">{item.label}</p>
  <h3>{item.title}</h3>
  <p class="package-best">{item.bestFor}</p>
  <p>{item.description}</p>
  <ul>
    {item.includes.map((include) => <li>{include}</li>)}
  </ul>
  <div class="package-footer">
    <span>{statusLabel}</span>
  </div>
</article>
