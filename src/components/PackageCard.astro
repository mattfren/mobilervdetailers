---
import type { Package } from "../data/packages";
import { getQuoteAction } from "../data/site";

interface Props {
  item: Package;
  featured?: boolean;
}

const { item, featured = false } = Astro.props;
const quoteAction = getQuoteAction();
---

<article class:list={["package-card", featured && "is-featured"]}>
  <p class="card-eyebrow">{item.label}</p>
  <h3>{item.title}</h3>
  <p class="package-best">{item.bestFor}</p>
  <p>{item.description}</p>
  <ul>
    {item.includes.map((include) => <li>{include}</li>)}
  </ul>
  <div class="package-footer">
    <span>{item.priceLabel}</span>
    <a href={quoteAction.href} target={quoteAction.external ? "_blank" : undefined} rel={quoteAction.external ? "noreferrer" : undefined}>{quoteAction.label}</a>
  </div>
</article>
