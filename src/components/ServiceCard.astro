---
import type { Service } from "../data/services";

interface Props {
  service: Service;
}

const { service } = Astro.props;
---

<article class="service-card" id={service.id}>
  <div class="service-card-media">
    <img src={service.image} alt={service.alt} width="900" height="620" loading="lazy" />
  </div>
  <div class="service-card-body">
    <p class="card-eyebrow">{service.eyebrow}</p>
    <h3>{service.title}</h3>
    <p>{service.summary}</p>
    <ul>
      {service.bullets.map((bullet) => <li>{bullet}</li>)}
    </ul>
  </div>
</article>
