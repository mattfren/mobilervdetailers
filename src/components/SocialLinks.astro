---
import { isTodoLink, launchApprovals, site } from "../data/site";

interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;

const links = [
  {
    label: "Facebook",
    href: site.facebookUrl,
    icon: "/images/optimized/social-facebook.svg",
    color: "#1877F2",
    ariaLabel: "Follow Mobile RV Detailers on Facebook"
  },
  {
    label: "Google",
    href: site.googleBusinessUrl,
    icon: "/images/optimized/social-google.svg",
    color: "#4285F4",
    ariaLabel: "Find Mobile RV Detailers on Google"
  },
  {
    label: "Reviews",
    href: site.googleReviewsUrl,
    icon: "/images/optimized/social-google-review.svg",
    color: "#FBBC05",
    ariaLabel: "See Mobile RV Detailers Google reviews"
  },
  {
    label: "Instagram",
    href: site.instagramUrl,
    icon: "/images/optimized/social-instagram.svg",
    color: "#D62976",
    ariaLabel: "Follow Mobile RV Detailers on Instagram"
  },
  {
    label: "Yelp",
    href: site.yelpUrl,
    icon: "/images/optimized/social-yelp.svg",
    color: "#D32323",
    ariaLabel: "Find Mobile RV Detailers on Yelp"
  }
].filter((link) => !isTodoLink(link.href) && (link.label !== "Reviews" || launchApprovals.reviewsApproved));
---

{links.length > 0 && (
  <div class:list={["social-links", compact && "social-links-compact"]} aria-label="Social links">
    {links.map((link) => (
      <a
        class="social-link"
        href={link.href}
        target="_blank"
        rel="noreferrer"
        aria-label={link.ariaLabel}
        style={`--social-color: ${link.color};`}
      >
        <span class="social-icon" aria-hidden="true">
          <img src={link.icon} alt="" width="64" height="64" loading="lazy" />
        </span>
        {!compact && <strong class="social-label">{link.label}</strong>}
      </a>
    ))}
  </div>
)}
