---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { getMessengerAction, getQuoteAction, getTextAction, localBusinessJsonLd } from "../data/site";

const title = "Request an RV Detailing Quote | Mobile RV Detailers";
const description =
  "Contact Mobile RV Detailers for a quote on mobile RV washing, wax soap hand drying, roof cleaning, black streak removal, and awning cleaning in Canton, TX.";

const quoteAction = getQuoteAction();
const messengerAction = getMessengerAction();
const textAction = getTextAction();
---

<BaseLayout title={title} description={description} path="/contact" jsonLd={localBusinessJsonLd()}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Request an RV detailing quote.</h1>
      <p>
        The strongest quote starts with RV length, condition, parking location, requested services, and photos of the areas that need attention.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <article class="contact-card">
        <h2>Request quote</h2>
        <p>Use the quote form path for RV details, photos, service location notes, water/electricity availability, and preferred timing. Messenger is available for quick follow-up.</p>
        <div class="contact-actions">
          <a class="btn btn-red" href={quoteAction.href} target={quoteAction.external ? "_blank" : undefined} rel={quoteAction.external ? "noreferrer" : undefined}>{quoteAction.label}</a>
          <a class="btn btn-ghost" href={textAction.href}>{textAction.label}</a>
          <a class="btn btn-ghost" href={messengerAction.href} target="_blank" rel="noreferrer">{messengerAction.label}</a>
        </div>
      </article>

      <article class="contact-card">
        <h2>Connect online</h2>
        <p>Follow the social pages for current photos, updates, reviews, and online contact options.</p>
        <div class="contact-actions">
          <SocialLinks compact />
        </div>
      </article>

      <article class="contact-card">
        <h2>Quote checklist</h2>
        <p>Have these ready: RV type, length, year/make/model, parked location, services wanted, condition level, water/electricity availability, site permission, and photos of the front, rear, both sides, roof if safely available, awning, wheels, and problem areas.</p>
        <div class="contact-actions">
          <a class="btn btn-ghost" href="/services">View Services</a>
        </div>
      </article>
    </div>
  </section>

  <CTASection title="Ready to clean up the exterior?" text="Send the RV details, location, services needed, and photos so the quote can be planned around the job." />
</BaseLayout>
