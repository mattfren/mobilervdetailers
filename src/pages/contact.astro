---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { getMessengerAction, getQuoteAction, localBusinessJsonLd } from "../data/site";

const title = "Request an RV Detailing Quote | Mobile RV Detailers";
const description =
  "Contact Mobile RV Detailers for a quote on mobile RV washing, wax soap and hand drying, roof cleaning, black streak removal, and awning cleaning in Canton, TX.";

const quoteAction = getQuoteAction();
const messengerAction = getMessengerAction();
---

<BaseLayout title={title} description={description} path="/contact" jsonLd={localBusinessJsonLd()}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Request an RV detailing quote.</h1>
      <p>Send the RV details once. Get a clear quote before scheduling.</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <article class="contact-card">
        <h2>Request quote</h2>
        <p>Use the form for RV details, photos, location, utilities, and timing.</p>
        <div class="contact-actions">
          <a class="btn btn-red" href={quoteAction.href} target={quoteAction.external ? "_blank" : undefined} rel={quoteAction.external ? "noreferrer" : undefined}>{quoteAction.label}</a>
          <a class="btn btn-ghost" href={messengerAction.href} target="_blank" rel="noreferrer">{messengerAction.label}</a>
        </div>
      </article>

      <article class="contact-card">
        <h2>Connect online</h2>
        <p>See current work, updates, and business profiles.</p>
        <div class="contact-actions">
          <SocialLinks compact />
        </div>
      </article>
    </div>
  </section>

  <CTASection title="Ready for a cleaner RV exterior?" text="Start with the quote form. Add photos there." />
</BaseLayout>
