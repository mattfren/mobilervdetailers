---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/CTASection.astro";
import { localBusinessJsonLd } from "../data/site";

const title = "About Mobile RV Detailers | Canton, TX RV Exterior Care";
const description =
  "Learn about Mobile RV Detailers, the Canton, TX family business founded by Carl and Jana Fields to make RV detailing easier for local owners.";
---

<BaseLayout title={title} description={description} path="/about" jsonLd={localBusinessJsonLd()}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">About</p>
      <h1>Premium mobile RV care based in Canton, TX.</h1>
      <p>Family-owned exterior RV detailing without the drop-off.</p>
    </div>
  </section>

  <section class="section">
    <div class="container split-section">
      <div class="rich-text">
        <h2>Started from a real RV owner problem.</h2>
        <p>
          Mobile RV Detailers was founded in 2021 by Carl and Jana Fields after they bought their
          first RV and had trouble finding someone to detail it. That need became a mobile RV detailing
          family business serving Canton and nearby communities.
        </p>
        <h2>A better way to care for a parked RV.</h2>
        <p>
          RVs need a different service mindset: larger surfaces, roofs, awnings, black streaks, road film,
          and parked-RV access. The quote-first process keeps the work tied to the actual rig.
        </p>
      </div>
      <div class="about-trust-stack">
        <article class="info-card">
          <h3>Clear quote planning</h3>
          <p>Details, photos, access, route, and weather shape the final scope.</p>
        </article>
        <article class="info-card">
          <h3>RV-specific work</h3>
          <p>Exterior washing, roof or awning care, streaks, bugs, tar, wheels, and parked-RV access.</p>
        </article>
        <article class="info-card">
          <h3>Careful expectations</h3>
          <p>Results vary by surface, age, staining, oxidation, and previous care.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <div class="section-kicker">
        <p class="eyebrow">What to expect</p>
        <h2>Clear expectations for parked RV exterior care.</h2>
      </div>
      <div class="cards-grid">
        <article class="process-card">
          <h3>Premium care</h3>
          <p>Designed for owners who treat their RV as a serious investment.</p>
        </article>
        <article class="process-card">
          <h3>Mobile service</h3>
          <p>Built for home, storage facility, campground, and RV park service.</p>
        </article>
        <article class="process-card">
          <h3>Quote-first scope</h3>
          <p>Photos, condition, access, and services drive the quote.</p>
        </article>
        <article class="process-card">
          <h3>Family business</h3>
          <p>Founded by Carl and Jana Fields to make RV detailing easier and more practical for owners.</p>
        </article>
      </div>
    </div>
  </section>

  <CTASection title="Ready for mobile RV exterior care?" text="Request a quote and upload your photos in the form." />
</BaseLayout>
