---
import BaseLayout from "../layouts/BaseLayout.astro";
import GalleryGrid from "../components/GalleryGrid.astro";
import CTASection from "../components/CTASection.astro";
import { galleryItems } from "../data/gallery";
import { localBusinessJsonLd, site } from "../data/site";

const title = "RV Detailing Before & After Gallery | Mobile RV Detailers";
const description =
  "View Mobile RV Detailers before and after photos for RV exterior wash work, roof cleaning, awning cleaning, front-cap cleanup, wheel detail, and wax soap hand dry finish.";
---

<BaseLayout title={title} description={description} path="/gallery" jsonLd={localBusinessJsonLd()}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Gallery</p>
      <h1>Real RV exterior work.</h1>
      <p>Before/after photos, roof cleaning, awning care, front-cap cleanup, and wheel detail.</p>
    </div>
  </section>

  <section class="section">
    <div class="container proof-grid">
      <div class="proof-media">
        <img src={site.images.proof} alt="Before and after RV exterior cleaning result from Mobile RV Detailers photos" width="1400" height="900" loading="lazy" />
      </div>
      <div>
        <p class="eyebrow">Proof standard</p>
        <h2>Real photos, realistic expectations.</h2>
        <p class="lead">Every RV is different. Photos help set the right scope before service.</p>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="section-kicker">
        <p class="eyebrow">Gallery</p>
        <h2>RV detailing photos.</h2>
        <p class="lead">Exterior wash, roof, awning, front-cap, wheel, and before/after work.</p>
      </div>
      <GalleryGrid items={galleryItems} />
    </div>
  </section>

  <CTASection title="Want your RV next?" text="Request a quote and include photos in the form." />
</BaseLayout>
