---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import PackageCard from "../components/PackageCard.astro";
import CTASection from "../components/CTASection.astro";
import FAQ from "../components/FAQ.astro";
import { faqs } from "../data/faqs";
import { packages, pricingDisclaimer } from "../data/packages";
import { services } from "../data/services";
import { faqJsonLd, launchApprovals, localBusinessJsonLd, site } from "../data/site";

const title = launchApprovals.careClubApproved
  ? "RV Washing, Detail Packages & Care Club | Mobile RV Detailers"
  : "RV Washing & Exterior Detail Packages | Mobile RV Detailers";
const description =
  launchApprovals.careClubApproved
    ? "Explore Mobile RV Detailers exterior wash packages, roof or awning care, Full Exterior Detail packages, and the RV Care Club membership in Canton, TX."
    : "Explore Mobile RV Detailers exterior wash packages, roof or awning care, Full Exterior Detail packages, and custom RV detail quotes in Canton, TX.";

const serviceSchema = services.map((service) => ({
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.title,
  provider: {
    "@type": "ProfessionalService",
    name: site.name,
    telephone: site.phone
  },
  areaServed: site.serviceAreas.join(", "),
  description: service.summary
}));
---

<BaseLayout title={title} description={description} path="/services" jsonLd={[localBusinessJsonLd(), faqJsonLd(faqs.slice(0, 5)), ...serviceSchema]}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Services</p>
      <h1>Mobile RV exterior care, quoted clearly.</h1>
      <p>Choose the starting point. The quote is matched to the RV, condition, access, and photos.</p>
    </div>
  </section>

  {launchApprovals.careClubApproved && (
  <section class="section section-dark membership-section">
    <div class="container">
      <div class="section-kicker">
        <p class="eyebrow">RV Care Club</p>
        <h2>RV Care Club details are held until owner approval.</h2>
        <p class="lead">Membership language can be restored after prices, benefits, and terms are approved.</p>
      </div>
    </div>
  </section>
  )}

  <section class="section">
    <div class="container">
      <div class="cards-grid">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <div class="section-kicker">
        <p class="eyebrow">Packages</p>
        <h2>Start here.</h2>
        <p class="lead">{pricingDisclaimer}</p>
      </div>
      <div class="cards-grid package-grid">
        {packages.map((item, index) => <PackageCard item={item} featured={index === 0} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-section">
      <div>
        <p class="eyebrow">Quote inputs</p>
        <h2>What the quote needs.</h2>
        <p class="lead">RV length, location, condition, utilities, and photos of the problem areas.</p>
      </div>
      <div class="side-card-stack">
        <article class="info-card">
          <h3>Condition matters</h3>
          <p>Stains, roof buildup, road film, and custom requests can change the scope.</p>
        </article>
        <article class="info-card">
          <h3>Utilities and access matter</h3>
          <p>Water, electricity, space, and site permission are required.</p>
        </article>
        <article class="info-card">
          <h3>Photos help</h3>
          <p>Use the quote form to upload front, sides, roof, awning, wheels, and problem areas.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="section-kicker center">
        <p class="eyebrow">Service questions</p>
        <h2>Quick service answers.</h2>
      </div>
      <FAQ items={faqs.slice(0, 5)} />
    </div>
  </section>

  <CTASection title="Ready for the right RV detail quote?" text="Start with the form. Upload photos there." />
</BaseLayout>
