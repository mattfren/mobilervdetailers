---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceCard from "../components/ServiceCard.astro";
import PackageCard from "../components/PackageCard.astro";
import CTASection from "../components/CTASection.astro";
import FAQ from "../components/FAQ.astro";
import { faqs } from "../data/faqs";
import { packages, pricingDisclaimer } from "../data/packages";
import { services } from "../data/services";
import { faqJsonLd, launchApprovals, localBusinessJsonLd, site } from "../data/site";

const title = launchApprovals.careClubApproved
  ? "RV Washing, Detail Packages & Care Club | Mobile RV Detailers"
  : "RV Washing & Exterior Detail Packages | Mobile RV Detailers";
const description =
  launchApprovals.careClubApproved
    ? "Explore Mobile RV Detailers exterior wash packages, roof or awning care, Full Exterior Detail packages, and the RV Care Club membership in Canton, TX."
    : "Explore Mobile RV Detailers exterior wash packages, roof or awning care, Full Exterior Detail packages, and custom RV detail quotes in Canton, TX.";

const serviceSchema = services.map((service) => ({
  "@context": "https://schema.org",
  "@type": "Service",
  name: service.title,
  provider: {
    "@type": "ProfessionalService",
    name: site.name,
    telephone: site.phone
  },
  areaServed: site.serviceAreas.join(", "),
  description: service.summary
}));
---

<BaseLayout title={title} description={description} path="/services" jsonLd={[localBusinessJsonLd(), faqJsonLd(faqs.slice(0, 7)), ...serviceSchema]}>
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Services</p>
      <h1>RV exterior care that meets your rig where it is parked.</h1>
      <p>
        Mobile RV Detailers offers exterior washing, roof or awning care, black streak removal,
        Full Exterior Detail packages, and custom quote planning for owners who want practical RV care.
      </p>
    </div>
  </section>

  {launchApprovals.careClubApproved && (
  <section class="section section-dark membership-section">
    <div class="container">
      <div class="section-kicker">
        <p class="eyebrow">RV Care Club</p>
        <h2>RV Care Club details are held until owner approval.</h2>
        <p class="lead">Membership language can be restored after prices, benefits, and terms are approved.</p>
      </div>
    </div>
  </section>
  )}

  <section class="section">
    <div class="container">
      <div class="cards-grid">
        {services.map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <div class="section-kicker">
        <p class="eyebrow">Packages</p>
        <h2>Choose the scope, then confirm the quote.</h2>
        <p class="lead">{pricingDisclaimer}</p>
      </div>
      <div class="cards-grid package-grid">
        {packages.map((item, index) => <PackageCard item={item} featured={index === 0} />)}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container split-section">
      <div>
        <p class="eyebrow">Quote inputs</p>
        <h2>Photos and RV details make the quote stronger.</h2>
        <p class="lead">
          Share RV length, condition, service location, where it is parked, available water/electricity, and the exterior areas that need attention.
        </p>
      </div>
      <div class="side-card-stack">
        <article class="info-card">
          <h3>Condition matters</h3>
          <p>Age, staining, roof buildup, awning condition, road film, and custom requests can change the scope and timing.</p>
        </article>
        <article class="info-card">
          <h3>Utilities and access matter</h3>
          <p>Mobile RV Detailers currently requires water and electricity at the customer location, plus permission for mobile washing/detailing where the RV is parked.</p>
        </article>
        <article class="info-card">
          <h3>Photos matter</h3>
          <p>Front cap, rear, both sides, roof if safely available, awning, wheels, and problem-area photos help prevent quote surprises.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="section-kicker center">
        <p class="eyebrow">Service questions</p>
        <h2>Answers before you request a quote.</h2>
      </div>
      <FAQ items={faqs.slice(0, 7)} />
    </div>
  </section>

  <CTASection title="Ready to quote the right RV detail?" text="Send the RV details and photos so the exterior care scope can be quoted accurately." />
</BaseLayout>
