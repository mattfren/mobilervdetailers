---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import ServiceCard from "../components/ServiceCard.astro";
import PackageCard from "../components/PackageCard.astro";
import GalleryGrid from "../components/GalleryGrid.astro";
import CTASection from "../components/CTASection.astro";
import FAQ from "../components/FAQ.astro";
import Reviews from "../components/Reviews.astro";
import { faqs } from "../data/faqs";
import { galleryItems } from "../data/gallery";
import { packages, pricingDisclaimer } from "../data/packages";
import { services } from "../data/services";
import { faqJsonLd, launchApprovals, localBusinessJsonLd, site } from "../data/site";

const title = "Premium Mobile RV Detailing in Canton, TX | Mobile RV Detailers";
const description =
  launchApprovals.careClubApproved
    ? "Mobile RV Detailers provides mobile RV wash packages, roof or awning care, black streak removal, Full Exterior Detail packages, and RV Care Club membership in Canton, TX."
    : "Mobile RV Detailers provides mobile RV wash packages, roof or awning care, black streak removal, Full Exterior Detail packages, and custom RV detail quotes in Canton, TX.";

const process = [
  {
    title: "Request a quote",
    text: "Send the RV details, location, utilities, and photos in one form."
  },
  {
    title: "Confirm the scope",
    text: "The quote is matched to the RV size, condition, access, and service needs."
  },
  {
    title: "Get on the schedule",
    text: "Once approved, service is planned around route, access, and weather."
  }
];
---

<BaseLayout title={title} description={description} path="/" jsonLd={[localBusinessJsonLd(), faqJsonLd(faqs.slice(0, 4))]}>
  <Hero />

  <section class="section section-light">
    <div class="container proof-grid">
      <div class="proof-media">
        <figure class="proof-compare" aria-label="Before and after RV exterior cleaning comparison">
          <div class="proof-panel">
            <img src={site.images.proofBefore} alt="Before RV exterior cleaning side panel" width="720" height="820" loading="lazy" />
            <span>Before</span>
          </div>
          <div class="proof-panel">
            <img src={site.images.proofAfter} alt="After RV exterior cleaning side panel" width="720" height="820" loading="lazy" />
            <span>After</span>
          </div>
        </figure>
      </div>
      <div class="proof-copy">
        <p class="eyebrow">Before and after proof</p>
        <h2>Visible exterior cleanup.</h2>
        <p class="lead">
          Real RV photos show the goal: cleaner panels, brighter trim, clearer wheels, and better-looking travel surfaces.
        </p>
        <ul class="proof-list">
          <li>Realistic expectations before the quote.</li>
          <li>Roof, awning, wheels, front cap, and panels reviewed by condition.</li>
          <li>Scope matched to what the RV actually needs.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-kicker">
        <p class="eyebrow">RV-specific exterior care</p>
        <h2>Exterior RV care where the rig sits.</h2>
        <p class="lead">Wash, roof, awning, black streak, bug, tar, and finish work by quote.</p>
      </div>
      <div class="cards-grid">
        {services.slice(0, 6).map((service) => <ServiceCard service={service} />)}
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <div class="section-kicker">
        <p class="eyebrow">Quote-based packages</p>
        <h2>Pick a starting point.</h2>
        <p class="lead">{pricingDisclaimer}</p>
      </div>
      <div class="cards-grid package-grid">
        {packages.map((item, index) => <PackageCard item={item} featured={index === 0} />)}
      </div>
      {launchApprovals.careClubApproved && (
      <article class="home-care-club-callout">
        <div>
          <p class="eyebrow">RV Care Club</p>
          <h3>RV Care Club</h3>
          <p>Membership details are available after the program terms are confirmed.</p>
        </div>
      </article>
      )}
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <div class="section-kicker">
        <p class="eyebrow">How it works</p>
        <h2>Simple quote-first process.</h2>
      </div>
      <div class="process-grid">
        {process.map((item) => (
          <article class="process-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container split-section">
      <div>
        <p class="eyebrow">Why Mobile RV Detailers</p>
        <h2>Premium exterior care without moving the RV.</h2>
        <p class="lead">
          Built for owners who want the RV cleaned at home, storage, RV park, campground, or wherever it is parked.
          Customer-location water and electricity are required.
        </p>
      </div>
      <div class="side-card-stack">
        <article class="info-card">
          <h3>Mobile by design</h3>
          <p>Planned around the parked RV, access, utilities, and route.</p>
        </article>
        <article class="info-card">
          <h3>RV-first scope</h3>
          <p>Exterior wash, roof or awning care, streaks, bugs, tar, wax soap, and hand dry.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section about-home-section">
    <div class="container split-section">
      <div>
        <p class="eyebrow">About Mobile RV Detailers</p>
        <h2>Family-owned. Canton-based. RV-focused.</h2>
        <p class="lead">
          Founded in 2021 by Carl and Jana Fields after they struggled to find RV detailing for their own rig.
        </p>
        <p>
          The work stays practical: exterior washing, roof cleaning, awning cleaning, black streak treatment, bug and tar removal, and custom requests when the scope is clear.
        </p>
        <div class="hero-actions">
          <a class="btn btn-red" href="/about/">Read About Mobile RV Detailers</a>
          <a class="btn btn-ghost" href="/service-areas/">Service Areas</a>
        </div>
      </div>
      <div class="about-home-panel">
        <article class="info-card">
          <h3>Local base</h3>
          <p>Canton, TX base with route-based scheduling.</p>
        </article>
        <article class="info-card">
          <h3>Photo-led quote</h3>
          <p>Photos help confirm the right scope before scheduling.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="section-kicker">
        <p class="eyebrow">Gallery preview</p>
        <h2>Real RV exterior work.</h2>
        <p class="lead">Exterior wash, roof, awning, front-cap, wheel, and before/after photos.</p>
      </div>
      <GalleryGrid items={galleryItems.slice(0, 3)} />
    </div>
  </section>

  <Reviews />

  <section class="section">
    <div class="container">
      <div class="section-kicker center">
        <p class="eyebrow">Common questions</p>
        <h2>Quick answers before you quote.</h2>
      </div>
      <FAQ items={faqs.slice(0, 4)} />
    </div>
  </section>

  <CTASection />
</BaseLayout>
