---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import PackageCard from "../components/PackageCard.astro";
import GalleryGrid from "../components/GalleryGrid.astro";
import CTASection from "../components/CTASection.astro";
import { galleryItems } from "../data/gallery";
import { packages, pricingDisclaimer } from "../data/packages";
import { launchApprovals, localBusinessJsonLd, site } from "../data/site";

const title = "Premium Mobile RV Detailing in Canton, TX | Mobile RV Detailers";
const description =
  launchApprovals.careClubApproved
    ? "Mobile RV Detailers provides mobile RV wash packages, roof or awning care, black streak removal, Full Exterior Detail packages, and RV Care Club membership in Canton, TX."
    : "Mobile RV Detailers provides mobile RV wash packages, roof or awning care, black streak removal, Full Exterior Detail packages, and custom RV detail quotes in Canton, TX.";

const process = [
  {
    title: "Request a quote",
    text: "Share the RV, location, water and electricity access, and photos."
  },
  {
    title: "Confirm the scope",
    text: "Get the right wash, add-on, or full exterior detail."
  },
  {
    title: "Get on the schedule",
    text: "Approve the quote, then plan the route and weather window."
  }
];
---

<BaseLayout title={title} description={description} path="/" jsonLd={[localBusinessJsonLd()]}>
  <Hero />

  <section class="section section-light">
    <div class="container proof-grid">
      <div class="proof-media">
        <figure class="proof-compare" aria-label="Before and after RV exterior cleaning comparison">
          <div class="proof-panel">
            <img src={site.images.proofBefore} alt="Before RV exterior cleaning side panel" width="720" height="820" loading="lazy" />
            <span>Before</span>
          </div>
          <div class="proof-panel">
            <img src={site.images.proofAfter} alt="After RV exterior cleaning side panel" width="720" height="820" loading="lazy" />
            <span>After</span>
          </div>
        </figure>
      </div>
      <div class="proof-copy">
        <p class="eyebrow">Before and after proof</p>
        <h2>Visible exterior cleanup.</h2>
        <p class="lead">
          Real RV photos. Cleaner panels, brighter trim, clearer wheels, and better-looking travel surfaces.
        </p>
        <ul class="proof-list">
          <li>Exterior, roof, awning, wheels, and front cap reviewed by condition.</li>
          <li>Scope matched to what the RV actually needs.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <div class="section-kicker">
        <p class="eyebrow">Quote-based packages</p>
        <h2>Pick a starting point.</h2>
        <p class="lead">{pricingDisclaimer}</p>
      </div>
      <div class="cards-grid package-grid">
        {packages.map((item, index) => <PackageCard item={item} featured={index === 0} />)}
      </div>
      {launchApprovals.careClubApproved && (
      <article class="home-care-club-callout">
        <div>
          <p class="eyebrow">RV Care Club</p>
          <h3>RV Care Club</h3>
          <p>Membership details are available after the program terms are confirmed.</p>
        </div>
      </article>
      )}
    </div>
  </section>

  <section class="section section-dark">
    <div class="container">
      <div class="section-kicker">
        <p class="eyebrow">How it works</p>
        <h2>Three steps. No shop drop-off.</h2>
      </div>
      <div class="process-grid">
        {process.map((item) => (
          <article class="process-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section about-home-section">
    <div class="container split-section">
      <div>
        <p class="eyebrow">About Mobile RV Detailers</p>
        <h2>Family-owned. Canton-based. RV-focused.</h2>
        <p class="lead">
          Founded in 2021 by Carl and Jana Fields after they struggled to find RV detailing for their own rig.
        </p>
        <div class="hero-actions">
          <a class="btn btn-red" href="/about/">Read the Story</a>
          <a class="btn btn-ghost" href="/service-areas/">Service Areas</a>
        </div>
      </div>
      <div class="about-home-panel">
        <article class="info-card">
          <h3>Local base</h3>
          <p>Canton, TX base with route-based scheduling.</p>
        </article>
        <article class="info-card">
          <h3>Photo-led quote</h3>
          <p>Photos help confirm the right scope before scheduling.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section section-light">
    <div class="container">
      <div class="section-kicker">
        <p class="eyebrow">Gallery preview</p>
        <h2>Real RV exterior work.</h2>
        <p class="lead">Before/after proof, roofs, awnings, wheels, and finish work.</p>
      </div>
      <GalleryGrid items={galleryItems.slice(0, 3)} />
    </div>
  </section>

  <CTASection />
</BaseLayout>
